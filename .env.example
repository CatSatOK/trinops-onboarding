# --- Runtime mode -----------------------------------------------------------
# true  = no external services: seed hires, outbox dir for email/Slack, demo calendar
# false = real Gmail + Google Calendar + Slack (requires credentials below)
DEMO_MODE=true

# --- Admin API auth ----------------------------------------------------------
# Protects the onboarding endpoints when DEMO_MODE=false. Send it as the
# X-API-Key request header; the Streamlit tracker reads the same value and
# sends it automatically. Leave empty in demo mode (auth is disabled there).
ADMIN_API_KEY=

# --- Database ----------------------------------------------------------------
# SQLite for demo; swap for PostgreSQL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/onboarding
DATABASE_URL=sqlite:///./data/onboarding.db

# --- Google APIs (only used when DEMO_MODE=false) ----------------------------
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary

# --- Slack (only used when DEMO_MODE=false) ----------------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#team-general

# --- Company details (appear on emails, welcome pack, calendar invites) ------
COMPANY_NAME=Company A
COMPANY_EMAIL=people@example.com
COMPANY_ADDRESS=1 Example Street, Example Town, EX1 2MP
HANDBOOK_URL=https://example.com/handbook
IT_CONTACT=it-support@example.com
PEOPLE_CONTACT=people@example.com

# --- First-week schedule -----------------------------------------------------
DAY1_START_HOUR=9
TEAM_INTRO_HOUR=11
PROBATION_REVIEW_HOUR=10
EVENT_DURATION_MINUTES=60
PROBATION_PERIOD_DAYS=90

# --- Demo fault injection -----------------------------------------------------
# Steps listed here fail on their FIRST attempt in demo mode, then succeed on
# retry — so the failed -> retry -> success path is visible in the tracker.
# Set to [] for clean demo runs.
DEMO_FLAKY_STEPS=["slack_notification"]

# --- Paths -------------------------------------------------------------------
PACK_DIR=data/welcome_packs
OUTBOX_DIR=data/outbox
CALENDAR_DIR=data/calendar
SEED_EMPLOYEES_FILE=seed/employees.json

# --- Tracker -----------------------------------------------------------------
# Base URL the Streamlit tracker uses to reach the API (docker uses http://app:8000)
API_BASE_URL=http://localhost:8000
# Password gate for the Streamlit tracker UI. Ignored in demo mode. When
# DEMO_MODE=false the tracker refuses to start unless this is set (it exposes
# hire PII + trigger/retry actions, so it must not sit open on :8501).
TRACKER_PASSWORD=
